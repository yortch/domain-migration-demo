# Shared Configuration - All Environments
# Do not commit secrets to this file

# === Primary Domain (LEGACY - TO BE MIGRATED) ===
PRIMARY_DOMAIN=old.com
PRIMARY_DOMAIN_API=https://api.old.com
PRIMARY_DOMAIN_AUTH=https://auth.old.com
PRIMARY_DOMAIN_NOTIFICATIONS=https://notifications.old.com

# === Secondary Domains (LEGACY) ===
BACKUP_DOMAIN=backup.old.com
CDN_DOMAIN=cdn.old.com
METRICS_DOMAIN=metrics.old.com
LEGACY_DOMAIN=legacy.old.com
HEALTH_CHECK_DOMAIN=health.old.com

# === Email Configuration ===
MAIL_FROM_DOMAIN=old.com
NOTIFICATION_EMAIL=notifications@old.com
ADMIN_EMAIL=admin@old.com
SUPPORT_EMAIL=support@old.com
TECH_EMAIL=tech@old.com
ALERTS_EMAIL=alerts@old.com

# === Database ===
DB_PRIMARY_HOST=db.old.com
DB_PRIMARY_USER=legacy_admin
DB_BACKUP_HOST=db-backup.old.com
DB_BACKUP_USER=legacy_admin

# === Service Endpoints ===
SERVICE_AUTH_URL=https://auth.old.com/oauth
SERVICE_WEBHOOK_URL=https://webhook.old.com/api
SERVICE_LOGGING_URL=https://logs.old.com/api
SERVICE_AUDIT_URL=https://audit.old.com/api
SERVICE_CACHE_URL=redis.old.com:6379

# === Security & SSL ===
SSL_CERT_DOMAIN=old.com
SSL_CERT_PATH=/etc/ssl/certs/old.com.crt
SSL_KEY_PATH=/etc/ssl/private/old.com.key

# === Legacy System References ===
LEGACY_SYSTEM_API=https://legacy.old.com/api/v1
LEGACY_OAUTH_PROVIDER=https://legacy.old.com/oauth2
LEGACY_ADMIN_DASHBOARD=https://admin.old.com/dashboard

# === Webhook Callbacks ===
WEBHOOK_CALLBACK_URL=https://webhook.old.com/payments
WEBHOOK_STATUS_URL=https://webhook.old.com/status
WEBHOOK_ERROR_URL=https://webhook.old.com/errors

# === CORS & Cross-Origin ===
CORS_ALLOWED_ORIGINS=https://old.com,https://www.old.com,https://admin.old.com,https://api.old.com
CSRF_SAFE_DOMAINS=old.com,*.old.com

# === Feature Flags (Using old.com references) ===
FF_MIGRATE_TO_NEW_DOMAIN=false
FF_DUAL_WRITE_NEW_SYSTEM=false
FF_NEW_DOMAIN_REDIRECT=false
MIGRATION_CUTOVER_DATE=2024-Q4
